# Base URL gateway AutoClaim (tanpa trailing slash).
VITE_API_AUTOCLAIM_BASE_URL=https://fossil-algebra-humorist.ngrok-free.dev

# Channel header dikirim di setiap request (lihat lib/api/client.ts).
VITE_API_CHANNEL=cust_mobile_app

# Toggle service dummy/mock global untuk fitur yang belum disetel spesifik.
VITE_USE_MOCK_SERVICES=false

# Toggle spesifik. Nilai ini override VITE_USE_MOCK_SERVICES.
# OCR/upload real, hasil damage real, payment real, dan cek asuransi real.
VITE_USE_MOCK_SCAN_SERVICES=false
VITE_USE_MOCK_DAMAGE_ANALYSIS=false
VITE_USE_MOCK_INSURANCE_CHECK=false

# Upload file publik Seleris (tanpa login) untuk foto damage saat analisis pra-login.
# Default sudah menunjuk ke gateway upload Seleris production.
VITE_SELERIS_UPLOAD_URL=https://api-gateway.seleris.id/v1/seleris-credit-cover/web/upload-file
